# =============================================================================
# env/office-wrt.env -- Build config for office-wrt (office AP)
#
# Usage:
#   wrtstack build office-wrt
#   wrtstack flash office-wrt --device=/dev/sdb
#
# The most recent .tar.gz in backups/office-wrt/ is used automatically (Mode A).
# The HOSTNAME / LAN_IP / SSH_PUBKEY vars below are only needed when no backup
# exists (Mode B -- first build or recovery without a backup tarball).
#
# Network identity (from production backup):
#   Hostname   : office-wrt
#   LAN IP     : 192.168.1.2/24  (gateway: 192.168.1.1)
#   homenet    : 192.168.2.2/24  (br-lan.20)
#   serversNet : DHCP via br-lan.30
#   guestNet   : 192.168.6.2/24  (br-lan.60)
#   WAN        : none (pure AP -- dnsmasq/firewall/odhcpd disabled)
#   Roaming    : 802.11r + DAWN (mobility_domain=a1b2, all radios)
# =============================================================================

# Mode B fallback -- only used when backups/office-wrt/ is empty.
#HOSTNAME=office-wrt
#LAN_IP=192.168.4.3
#SSH_PUBKEY="ssh-ed25519 AAAA..."

# Full OpenSSL-linked hostapd -- required for WPA3-SAE + 802.11r.
# Replaces the default stripped wpad-basic-wolfssl.
PACKAGES="
    hostapd-openssl
    dawn
    luci-app-dawn
    luci-app-attendedsysupgrade
"

PACKAGES_REMOVE="wpad-basic-wolfssl wpad-wolfssl wpad-openssl"
