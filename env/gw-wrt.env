# =============================================================================
# env/gw-wrt.env — Build config for gw (gateway router)
#
# Usage:
#   wrtstack build gw-wrt
#   wrtstack flash gw-wrt --device=/dev/sdb
#
# The most recent .tar.gz in backups/gw-wrt/ is used automatically (Mode A).
# The HOSTNAME / LAN_IP / SSH_PUBKEY vars below are only needed when no backup
# exists (Mode B — first build or recovery without a backup tarball).
#
# Network identity (from production backup):
#   Hostname   : gw
#   LAN IP     : 192.168.1.1  (br-lan.1)
#   homenet    : 192.168.2.1  (br-lan.20)
#   serversNet : 192.168.3.1  (br-lan.30)
#   guestNet   : 192.168.6.1  (br-lan.60)
#   UIotNet    : 192.168.8.1  (br-lan.70)
#   WAN        : DHCP
#   Domain     : ancapistan.io
# =============================================================================

# Mode B fallback — only used when backups/gw-wrt/ is empty.
# LAN_IP must be a reachable first-boot address (configure production IP via LuCI).
#HOSTNAME=gw
#LAN_IP=192.168.4.2
#SSH_PUBKEY="ssh-ed25519 AAAA..."

# Full OpenSSL-linked hostapd — required for WPA3-SAE + 802.11r.
# Replaces the default stripped wpad-basic-wolfssl.
PACKAGES="
    hostapd-openssl
    dawn
    luci-app-dawn
    kmod-wireguard
    wireguard-tools
    luci-app-wireguard
    luci-proto-wireguard
    ddns-scripts
    ddns-scripts-namecheap
    luci-app-ddns
    prometheus-node-exporter-lua
    umdns
    ipset
    kmod-nft-set
    luci-app-attendedsysupgrade
"

PACKAGES_REMOVE="wpad-basic-wolfssl wpad-wolfssl wpad-openssl"
